rule tumour_immune_interface:
    input:
        "results/classified/{sample}.h5ad"
    output:
        distances="results/interface/{sample}_interface_distances.csv",
        summary="results/interface/{sample}_interface_summary.csv"
    shell:
        """
        python scripts/tumour_immune_interface.py \
            --input {input} \
            --output {output.distances} \
            --summary {output.summary}
        """


