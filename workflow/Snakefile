rule plot_tissue_overlays:
    input:
        h5ad="results/classified/{sample}.h5ad"
    output:
        "figures/tissue_overlays/{sample}/immune_states_tissue_overlay.png"
    params:
        visium_path=lambda wc: SAMPLE_PATHS[wc.sample],
        outdir="figures/tissue_overlays/{sample}"
    shell:
        """
        python scripts/plot_tissue_overlays.py \
            --input {input.h5ad} \
            --visium_path {params.visium_path} \
            --outdir {params.outdir}
        """


rule plot_morphology_overlays:
    input:
        h5ad="results/classified/{sample}.h5ad"
    output:
        tissue="figures/morphology_overlays/{sample}/tissue_morphology_reference.png",
        melanoma="figures/morphology_overlays/{sample}/melanoma_programme_morphology_overlay.png",
        stromal="figures/morphology_overlays/{sample}/stromal_programme_morphology_overlay.png",
        interferon="figures/morphology_overlays/{sample}/interferon_response_morphology_overlay.png",
        tcell="figures/morphology_overlays/{sample}/tcell_infiltration_morphology_overlay.png",
        cytotoxic="figures/morphology_overlays/{sample}/cytotoxic_activity_morphology_overlay.png",
        immune="figures/morphology_overlays/{sample}/immune_states_morphology_overlay.png"
    params:
        visium_path=lambda wc: SAMPLE_PATHS[wc.sample],
        outdir="figures/morphology_overlays/{sample}"
    shell:
        """
        python scripts/plot_morphology_overlays.py \
            --input {input.h5ad} \
            --visium_path {params.visium_path} \
            --outdir {params.outdir}
        """


